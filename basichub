--// Services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Stats = game:GetService("Stats")
local VirtualInputManager = game:GetService("VirtualInputManager")
local UIS = game:GetService("UserInputService")

local Player = Players.LocalPlayer

--// Settings
local BASE_SIZE = 35
local MAX_SIZE = 500
local SPEED_FACTOR = 0.05
local PARRY_MARGIN = 0.1
local SMOOTH_FACTOR = 0.1
local SAFE_DISTANCE = 1000
local FIELD_BUFFER = 1 -- أقصى مسافة خارج المجال يُسمح بالـParry

--// Player
local Character
local HRP

--// State
local Field
local ParryUsed = false
local CurrentTarget = nil
local CurrentSize = BASE_SIZE
local ManualSpam = false

-------------------------------------------------
-- Character Setup
-------------------------------------------------
local function SetupCharacter()
	Character = Player.Character or Player.CharacterAdded:Wait()
	HRP = Character:WaitForChild("HumanoidRootPart")

	if Field then Field:Destroy() end

	Field = Instance.new("Part")
	Field.Shape = Enum.PartType.Ball
	Field.Anchored = true
	Field.CanCollide = false
	Field.Transparency = 0.6
	Field.Material = Enum.Material.SmoothPlastic
	Field.Size = Vector3.new(BASE_SIZE, BASE_SIZE, BASE_SIZE)
	Field.Parent = workspace

	CurrentSize = BASE_SIZE
end

SetupCharacter()
Player.CharacterAdded:Connect(function()
	task.wait(1)
	SetupCharacter()
end)

-------------------------------------------------
-- Get Real Ball
-------------------------------------------------
local function GetBall()
	local folder = workspace:FindFirstChild("Balls")
	if not folder then return end
	for _,ball in pairs(folder:GetChildren()) do
		if ball:GetAttribute("realBall") then
			return ball
		end
	end
end

-------------------------------------------------
-- Manual Spam Input
-------------------------------------------------
UIS.InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == Enum.KeyCode.E then
		ManualSpam = not ManualSpam
	end
end)

RunService.RenderStepped:Connect(function()
	if ManualSpam then
		VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game)
		VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
	end
end)

-------------------------------------------------
-- Main System
-------------------------------------------------
RunService.RenderStepped:Connect(function()
	if not HRP then return end
	local Ball = GetBall()
	if not Ball then return end
	local Velocity = Ball.AssemblyLinearVelocity
	if Ball:FindFirstChild("zoomies") then
		Velocity = Ball.zoomies.VectorVelocity
	end

	local Speed = Velocity.Magnitude
	if Speed <= 0 then return end

	local Distance = (HRP.Position - Ball.Position).Magnitude

	--=== حساب الحجم التدريجي للمجال ===--
	local PlayerSize = Character:GetExtentsSize().Magnitude
	local DesiredSize = BASE_SIZE + (PlayerSize * 0.5) + (Speed * SPEED_FACTOR)
	if DesiredSize > MAX_SIZE then DesiredSize = MAX_SIZE end

	-- تصحيح تدريجي
	CurrentSize = CurrentSize + (DesiredSize - CurrentSize) * SMOOTH_FACTOR
	Field.Size = Vector3.new(CurrentSize, CurrentSize, CurrentSize)
	Field.Position = HRP.Position

	--=== نظام Parry ===--
	local Target = Ball:GetAttribute("target")
	if Target ~= CurrentTarget then
		ParryUsed = false
		CurrentTarget = Target
	end

	local Radius = CurrentSize / 2
	local DistanceToField = math.max(Distance - Radius, 0)

	local Ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
	local TimeToField = (DistanceToField / Speed) - Ping

	-- Projection للتأكد من اقتراب الكرة
	local DirectionToPlayer = (HRP.Position - Ball.Position).Unit
	local VelocityTowardsPlayer = Velocity:Dot(DirectionToPlayer)
	local IsApproaching = VelocityTowardsPlayer > 0

	-- Parry يحدث قبل الاصطدام مباشرة
	if Target == Player.Name
	and not ParryUsed
	and IsApproaching
	and (DistanceToField <= FIELD_BUFFER or TimeToField <= PARRY_MARGIN) then

		VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,0)
		ParryUsed = true
	end
end)
