local function toggle(name,setting,y)
	local label = Instance.new("TextLabel",main)
	label.Size = UDim2.new(0.6,0,0,30)
	label.Position = UDim2.new(0.05,0,0,y)
	label.BackgroundTransparency = 1
	label.Text = name
	label.TextScaled = true
	label.TextColor3 = Color3.new(1,1,1)

	local btn = Instance.new("TextButton",main)
	btn.Size = UDim2.new(0,25,0,25)
	btn.Position = UDim2.new(0.8,0,0,y+2)
	btn.Text = ""
	btn.BackgroundColor3 = Color3.fromRGB(120,0,0)
	Instance.new("UICorner",btn)

	btn.MouseButton1Click:Connect(function()
		Settings[setting] = not Settings[setting]
		btn.BackgroundColor3 = Settings[setting] and Color3.fromRGB(0,200,0) or Color3.fromRGB(120,0,0)
	end)
end

