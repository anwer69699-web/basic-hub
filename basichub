```lua
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local UIS = game:GetService("UserInputService")
local VIM = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer

local function getHRP()
	local char = player.Character or player.CharacterAdded:Wait()
	return char:WaitForChild("HumanoidRootPart")
end

local hrp = getHRP()

player.CharacterAdded:Connect(function()
	hrp = getHRP()
end)

local Settings = {
	AutoParry = true,
	ManualSpam = false,
	BallPath = false,
	BallHitbox = false,
	PlayerHitbox = false,
	CheckDistance = true,
	CheckTime = true
}

local balls = {}

local function findBalls()
	local found = {}
	local ballsFolder = Workspace:FindFirstChild("Balls")
	if not ballsFolder then return found end

	for _,v in pairs(ballsFolder:GetDescendants()) do
		if v:IsA("BasePart") and v:GetAttribute("realBall") then
			table.insert(found,v)
		end
	end

	return found
end

RunService.Heartbeat:Connect(function()
	balls = findBalls()
end)

local function parry(times)
	times = times or 1
	for i=1,times do
		VIM:SendKeyEvent(true,Enum.KeyCode.F,false,game)
		VIM:SendKeyEvent(false,Enum.KeyCode.F,false,game)
	end
end

UIS.InputBegan:Connect(function(input,gp)
	if gp then return end
	if input.KeyCode == Enum.KeyCode.E then
		Settings.ManualSpam = not Settings.ManualSpam
	end
end)

RunService.RenderStepped:Connect(function()
	if Settings.ManualSpam then
		parry(5)
	end
end)

local AdaptiveTable = {
	{min=0,max=200,Time=0.45,Dist=50},
	{min=201,max=400,Time=0.35,Dist=70},
	{min=401,max=700,Time=0.25,Dist=95},
	{min=701,max=1000,Time=0.18,Dist=110},
	{min=1001,max=math.huge,Time=0.12,Dist=130}
}

local function getAdaptive(speed)
	for _,v in ipairs(AdaptiveTable) do
		if speed >= v.min and speed <= v.max then
			return v.Time,v.Dist
		end
	end
	return 0.4,60
end

RunService.Heartbeat:Connect(function()

	if not Settings.AutoParry then return end
	if not hrp then return end

	local playerPos = hrp.Position

	for _,ball in pairs(balls) do

		if not ball or not ball.Parent then continue end

		local ballPos = ball.Position
		local vel = ball.AssemblyLinearVelocity
		local speed = vel.Magnitude

		if speed < 1 then continue end

		local target = ball:GetAttribute("target")
		if target ~= player.Name then continue end

		local dist = (playerPos - ballPos).Magnitude

		local dirToPlayer = (playerPos - ballPos).Unit
		local ballDir = vel.Unit
		local dot = dirToPlayer:Dot(ballDir)

		if dot < 0.3 then continue end

		local futurePos = ballPos + vel * 0.18
		local predictedDist = (playerPos - futurePos).Magnitude
		local timeToHit = predictedDist / speed

		local adaptiveTime, adaptiveDistance = getAdaptive(speed)

		local shouldParry = false

		if Settings.CheckDistance and predictedDist <= adaptiveDistance then
			shouldParry = true
		end

		if Settings.CheckTime and timeToHit <= adaptiveTime then
			shouldParry = true
		end

		if Settings.CheckDistance and Settings.CheckTime then
			if predictedDist <= adaptiveDistance and timeToHit <= adaptiveTime then
				shouldParry = true
			else
				shouldParry = false
			end
		end

		if shouldParry then
			parry()
		end

	end

end)

local gui = Instance.new("ScreenGui",game.CoreGui)

local main = Instance.new("Frame",gui)
main.Size = UDim2.new(0,280,0,260)
main.Position = UDim2.new(0.03,0,0.4,0)
main.BackgroundColor3 = Color3.fromRGB(25,25,35)
main.Active = true
main.Draggable = true
Instance.new("UICorner",main)

local title = Instance.new("TextLabel",main)
title.Size = UDim2.new(1,0,0,35)
title.Text = "DotHub Ultra"
title.TextColor3 = Color3.fromRGB(255,0,0)
title.BackgroundTransparency = 1
title.TextScaled = true

local function toggle(name,setting,y)

	local label = Instance.new("TextLabel",main)
	label.Size = UDim2.new(0.6,0,0,30)
	label.Position = UDim2.new(0.05,0,0,y)
	label.BackgroundTransparency = 1
	label.Text = name
	label.TextScaled = true
	label.TextColor3 = Color3.new(1,1,1)

	local btn = Instance.new("TextButton",main)
	btn.Size = UDim2.new(0,25,0,25)
	btn.Position = UDim2.new(0.8,0,0,y+2)
	btn.Text = ""
	btn.BackgroundColor3 = Settings[setting] and Color3.fromRGB(0,200,0) or Color3.fromRGB(120,0,0)
	Instance.new("UICorner",btn)

	btn.MouseButton1Click:Connect(function()
		Settings[setting] = not Settings[setting]
		btn.BackgroundColor3 = Settings[setting] and Color3.fromRGB(0,200,0) or Color3.fromRGB(120,0,0)
	end)

end

toggle("Auto Parry","AutoParry",50)
toggle("Manual Spam","ManualSpam",90)
toggle("Ball Path","BallPath",130)
toggle("Ball Hitbox","BallHitbox",170)
toggle("Player Hitbox","PlayerHitbox",210)

local closeBtn = Instance.new("TextButton",main)
closeBtn.Size = UDim2.new(0.2,0,0,30)
closeBtn.Position = UDim2.new(0.7,0,0,5)
closeBtn.Text = "X"
closeBtn.BackgroundColor3 = Color3.fromRGB(255,0,0)

Instance.new("UICorner",closeBtn)

closeBtn.MouseButton1Click:Connect(function()
	gui:Destroy()
end)
