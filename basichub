local starterGUI = game:GetService("StarterGui")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local Stats = game:GetService("Stats")
local UIS = game:GetService("UserInputService")

local Player = Players.LocalPlayer

-- الحد الأقصى لمجال الدائرة
local MAX_RANGE = 30

wait(1)

starterGUI:SetCore("SendNotification",{
	Title = " نسخة العربarbix hub",
	Text = "Auto Parry العربي",
	Icon = "rbxassetid://135351041318579",
	Duration = 10
})

-- تحميل السكربت الأصلي (الدائرة + الفيجوال)
loadstring(game:HttpGet("https://scriptblox.com/raw/UPD-Blade-Ball-op-autoparry-with-visualizer-8652"))()

local Parried = false
local Connection = nil
local ManualSpam = false

-- اللاعب
local function getHRP()
	local char = Player.Character or Player.CharacterAdded:Wait()
	return char:WaitForChild("HumanoidRootPart")
end

local HRP = getHRP()

Player.CharacterAdded:Connect(function()
	HRP = getHRP()
end)

-- إيجاد الكرة
local function GetBall()
	for _, Ball in ipairs(workspace.Balls:GetChildren()) do
		if Ball:GetAttribute("realBall") then
			return Ball
		end
	end
end

-- إعادة ضبط الهدف
local function ResetConnection()
	if Connection then
		Connection:Disconnect()
		Connection = nil
	end
end

workspace.Balls.ChildAdded:Connect(function()

	local Ball = GetBall()
	if not Ball then return end

	ResetConnection()

	Connection = Ball:GetAttributeChangedSignal("target"):Connect(function()
		Parried = false
	end)

end)

-- زر السبام
UIS.InputBegan:Connect(function(input,gp)

	if gp then return end

	if input.KeyCode == Enum.KeyCode.E then
		ManualSpam = not ManualSpam
	end

end)

RunService.RenderStepped:Connect(function()

	if ManualSpam then
		VirtualInputManager:SendKeyEvent(true,Enum.KeyCode.F,false,game)
		VirtualInputManager:SendKeyEvent(false,Enum.KeyCode.F,false,game)
	end

end)

-- المحرك
RunService.PreSimulation:Connect(function()

	local Ball = GetBall()
	if not Ball or not HRP then return end

	local Velocity = Ball.AssemblyLinearVelocity

	if Ball:FindFirstChild("zoomies") then
		Velocity = Ball.zoomies.VectorVelocity
	end

	local Speed = Velocity.Magnitude
	if Speed <= 0 then return end

	local Distance = (HRP.Position - Ball.Position).Magnitude

	-- تعويض البنج
	local Ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()/1000
	local Check = (Distance / Speed) - Ping

	-- اتجاه الكرة
	local DirectionToPlayer = (HRP.Position - Ball.Position).Unit
	local BallDirection = Velocity.Unit
	local Dot = DirectionToPlayer:Dot(BallDirection)

	-- مجال الدائرة
	local InRange = Distance <= MAX_RANGE

	if Ball:GetAttribute("target") == Player.Name
	and Dot > 0.35
	and InRange
	and not Parried
	and Check <= 0.73 then

		VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,0)

		Parried = true
	end

end)
