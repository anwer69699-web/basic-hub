
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local UIS = game:GetService("UserInputService")
local VIM = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer

local function getHRP()
	local char = player.Character or player.CharacterAdded:Wait()
	return char:WaitForChild("HumanoidRootPart")
end

local hrp = getHRP()

player.CharacterAdded:Connect(function()
	hrp = getHRP()
end)

local Settings = {
	AutoParry = true,
	ManualSpam = false,
	BallPath = false,
	BallHitbox = false,
	PlayerHitbox = false,
	CheckDistance = true,
	CheckTime = true
}

local lastDistance = math.huge
local approachConfirm = 0
local parryLock = false
local currentBall = nil

local beam
local ballBox
local playerBox

local function findBall()
	local ballsFolder = Workspace:FindFirstChild("Balls")
	if not ballsFolder then return nil end
	for _,v in pairs(ballsFolder:GetDescendants()) do
		if v:IsA("BasePart") and v:GetAttribute("realBall") then
			return v
		end
	end
end

RunService.Heartbeat:Connect(function()
	if not currentBall or not currentBall.Parent then
		currentBall = findBall()

		if beam then beam:Destroy() beam=nil end
		if ballBox then ballBox:Destroy() ballBox=nil end
	end
end)

local function parry(times)
	times = times or 1
	for i=1,times do
		VIM:SendKeyEvent(true,Enum.KeyCode.F,false,game)
		VIM:SendKeyEvent(false,Enum.KeyCode.F,false,game)
	end
end

UIS.InputBegan:Connect(function(input,gp)
	if gp then return end
	if input.KeyCode == Enum.KeyCode.E then
		Settings.ManualSpam = not Settings.ManualSpam
	end
end)

RunService.RenderStepped:Connect(function()
	if Settings.ManualSpam then
		parry(5)
	end
end)

local AdaptiveTable = {
	{min=0,max=200,Time=0.45,Dist=50},
	{min=201,max=400,Time=0.35,Dist=70},
	{min=401,max=700,Time=0.25,Dist=95},
	{min=701,max=1000,Time=0.18,Dist=110},
	{min=1001,max=math.huge,Time=0.12,Dist=130}
}

local function getAdaptive(speed)
	for _,v in ipairs(AdaptiveTable) do
		if speed >= v.min and speed <= v.max then
			return v.Time,v.Dist
		end
	end
	return 0.4,60
end

RunService.Heartbeat:Connect(function()

	if not Settings.AutoParry then return end
	if not currentBall then return end
	if not hrp then return end
	if parryLock then return end

	local playerPos = hrp.Position
	local ballPos = currentBall.Position
	local vel = currentBall.AssemblyLinearVelocity

	local speed = vel.Magnitude
	if speed < 1 then return end

	local dist = (playerPos - ballPos).Magnitude

	local target = currentBall:GetAttribute("target")
	if target ~= player.Name then return end

	local dirToPlayer = (playerPos - ballPos).Unit
	local ballDir = vel.Unit

	local dot = dirToPlayer:Dot(ballDir)
	if dot < 0.3 then return end

	local approaching = dist < lastDistance
	lastDistance = dist

	if approaching then
		approachConfirm += 1
	else
		approachConfirm = 0
	end

	if approachConfirm < 2 then return end

	local futurePos = ballPos + vel * 0.18
	local predictedDist = (playerPos - futurePos).Magnitude
	local timeToHit = predictedDist / speed

	local adaptiveTime, adaptiveDistance = getAdaptive(speed)

	local shouldParry = false

	if Settings.CheckDistance and predictedDist <= adaptiveDistance then
		shouldParry = true
	end

	if Settings.CheckTime and timeToHit <= adaptiveTime then
		shouldParry = true
	end

	if Settings.CheckDistance and Settings.CheckTime then
		if predictedDist <= adaptiveDistance and timeToHit <= adaptiveTime then
			shouldParry = true
		else
			shouldParry = false
		end
	end

	if shouldParry then
		parryLock = true
		parry()
		task.delay(0.25,function()
			parryLock=false
		end)
	end

end)

local function updateVisuals()

	if Settings.BallPath and currentBall and hrp then

		if not beam then
			local a0 = Instance.new("Attachment",currentBall)
			local a1 = Instance.new("Attachment",hrp)

			beam = Instance.new("Beam")
			beam.Attachment0 = a0
			beam.Attachment1 = a1
			beam.Width0 = 0.2
			beam.Width1 = 0.2
			beam.Color = ColorSequence.new(Color3.fromRGB(255,0,0))
			beam.Parent = currentBall
		end

	elseif beam then
		beam:Destroy()
		beam=nil
	end

	if Settings.BallHitbox and currentBall then

		if not ballBox then
			ballBox = Instance.new("BoxHandleAdornment")
			ballBox.Adornee = currentBall
			ballBox.Size = Vector3.new(6,6,6)
			ballBox.Color3 = Color3.fromRGB(0,255,0)
			ballBox.Transparency = 0.5
			ballBox.AlwaysOnTop = true
			ballBox.Parent = currentBall
		end

	elseif ballBox then
		ballBox:Destroy()
		ballBox=nil
	end

	if Settings.PlayerHitbox and hrp then

		if not playerBox then
			playerBox = Instance.new("BoxHandleAdornment")
			playerBox.Adornee = hrp
			playerBox.Size = Vector3.new(4,6,2)
			playerBox.Color3 = Color3.fromRGB(0,150,255)
			playerBox.Transparency = 0.5
			playerBox.AlwaysOnTop = true
			playerBox.Parent = hrp
		end

	elseif playerBox then
		playerBox:Destroy()
		playerBox=nil
	end

end

RunService.RenderStepped:Connect(updateVisuals)

