local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local Stats = game:GetService("Stats")

local player = Players.LocalPlayer

-- CONFIG
local config = {
    baseHorizontalSpeed = 30,
    verticalSpeed = 35,
    flyHeight = 14,
    stopHorizontalDistance = 2.8, -- التوقف عند الوصول فوق الدلفري
    correctKey = "arbix hub",
}

-- VARIABLES
local char, hrp
local moving = false
local currentVelocity = Vector3.zero
local lastDir = Vector3.zero
local flyButton
local gui

local speedFactor = 0

-- STOP FUNCTION
getgenv().ARBIX_STOP = function()
    moving = false
    if gui then gui:Destroy() end
    getgenv().ARBIX_RUNNING = false
end

-- CHARACTER SETUP
local function SetupCharacter(c)
    char = c
    hrp = char:WaitForChild("HumanoidRootPart")
end
if player.Character then SetupCharacter(player.Character) end
player.CharacterAdded:Connect(SetupCharacter)

-- UTILS
local function Smooth(a,b,t)
    return a:Lerp(b,t)
end

local function StabilizeDirection(dir)
    if lastDir.Magnitude == 0 then
        lastDir = dir
        return dir
    end
    lastDir = lastDir:Lerp(dir,0.2)
    return lastDir
end

-- GET PING
local function GetPing()
    local ok, ping = pcall(function()
        return Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
    end)
    if ok and ping then
        return ping
    end
    return 60
end

-- ADAPTIVE SPEED
local function GetAdaptiveSpeed()
    local ping = GetPing()

    local modifier = 1

    if ping > 150 then
        modifier = 0.72
    elseif ping > 100 then
        modifier = 0.82
    elseif ping > 70 then
        modifier = 0.9
    end

    return config.baseHorizontalSpeed * modifier
end

-- FIND DELIVERY
local function FindTarget()
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return end

    for _, plot in pairs(plots:GetChildren()) do
        local sign = plot:FindFirstChild("PlotSign")
        if sign then
            local yourBase = sign:FindFirstChild("YourBase")
            if yourBase and yourBase.Enabled then
                return plot:FindFirstChild("DeliveryHitbox")
            end
        end
    end
end

-- SMART PATHING OFFSET
local function GetPathOffset()
    return Vector3.new(
        math.sin(tick()*2.1)*0.6,
        0,
        math.cos(tick()*1.7)*0.6
    )
end

-- MAIN MOVEMENT
local function MoveToTarget(target)

    if not hrp or not target then return end

    moving = true
    flyButton.Text = "Stop"

    local lifted = false
    local endPos = target.Position

    speedFactor = 0

    while moving and target.Parent do

        local dt = RunService.Heartbeat:Wait()

        local pos = hrp.Position
        local smartOffset = GetPathOffset()
        local targetPos = endPos + smartOffset

        local dir = targetPos - pos

        -- المسافة الأفقية فقط
        local horizontalDist = (Vector3.new(pos.X,0,pos.Z) - Vector3.new(endPos.X,0,endPos.Z)).Magnitude

        if horizontalDist <= config.stopHorizontalDistance then
            break
        end

        dir = StabilizeDirection(dir)

        -- acceleration
        speedFactor = math.clamp(speedFactor + dt*1.6,0,1)

        local baseSpeed = GetAdaptiveSpeed()

        -- natural speed fluctuation
        local variation = math.sin(tick()*6)*0.08 + (math.random()-0.5)*0.05

        local speed = baseSpeed * (speedFactor + variation)

        -- Anti-lagback speed cap
        speed = math.clamp(speed,0,34)

        -- horizontal
        local horizontalDir = Vector3.new(dir.X,0,dir.Z)
        local horizontal = Vector3.zero

        if horizontalDir.Magnitude > 0.1 then
            horizontal = horizontalDir.Unit * speed
        end

        local vertical = 0

        -- lift
        if not lifted then

            local err = config.flyHeight - pos.Y
            vertical = math.clamp(err*2,-config.verticalSpeed,config.verticalSpeed)

            if math.abs(err) < 0.6 then
                lifted = true
            end

        end

        -- jitter
        local jitter = Vector3.new(
            (math.random()-0.5)*0.22,
            (math.random()-0.5)*0.06,
            (math.random()-0.5)*0.22
        )

        local targetVelocity = Vector3.new(horizontal.X,vertical,horizontal.Z) + jitter

        currentVelocity = Smooth(currentVelocity,targetVelocity,math.clamp(dt*4,0,1))

        hrp.AssemblyLinearVelocity = currentVelocity

    end

    hrp.AssemblyLinearVelocity = Vector3.zero
    moving = false
    flyButton.Text = "Fly to Delivery"

end

-- DRAG SYSTEM
local function MakeDraggable(frame)

    local dragging, dragInput, dragStart, startPos

    frame.InputBegan:Connect(function(input)

        if input.UserInputType == Enum.UserInputType.MouseButton1 then

            dragging = true
            dragStart = input.Position
            startPos = frame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)

        end
    end)

    frame.InputChanged:Connect(function(input)

        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end

    end)

    RunService.RenderStepped:Connect(function()

        if dragging and dragInput then

            local delta = dragInput.Position - dragStart

            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )

        end
    end)

end

